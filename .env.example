# Anthropic API Key - get from https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Wallet encryption secret - use a strong random string
WALLET_ENCRYPTION_SECRET=your_strong_encryption_secret_here

# Solana RPC endpoint (devnet)
SOLANA_RPC_URL=https://api.devnet.solana.com

# Number of agents to spawn
NUM_AGENTS=3

# How often each agent makes a decision (in milliseconds)
AGENT_DECISION_INTERVAL_MS=30000
